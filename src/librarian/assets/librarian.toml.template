# .librarian.toml — repo-librarian configuration
# Docs: https://github.com/CCROWN2246/repo-librarian
# Every key shown commented has the default value; uncomment to change it.
schema_version = 1

[paths]
# index    = "_index"                      # generated: CATALOG.md, STALENESS.md, catalog.json, baselines.json
# inbox    = "_inbox"                      # raw uploads awaiting intake
# archive  = "_archive"                    # retired docs (excluded from the catalog)
# docs     = "."                           # where knowledge docs are scanned from (relative to repo root)
# artifacts = "librarian-artifacts.toml"   # registry for non-markdown artifacts

[scan]
# skip_dirs   = [".git", ".claude", "tests", "node_modules", "__pycache__", "backups", ".venv", "venv"]
# skip_files  = ["CLAUDE.md", "AGENTS.md", "KNOWLEDGE_PROTOCOL.md"]   # instructions, not knowledge
# covered_ext = [".sql", ".py", ".json", ".sh", ".ipynb"]  # these need a registry entry (coverage scan)
# coverage_skip = []                       # covered-ext files intentionally unregistered

[taxonomy]
# domains  = []                            # empty = free-form; non-empty = closed list, violations flagged
# statuses = ["authoritative", "provisional", "draft", "reference", "retired", "archived"]
# authorities = ["verified", "curated", "unverified"]

[index]
# absence_guard = true                     # advisory scan for confident "we don't have X" claims
# fail_on = []                             # gate categories for `librarian index --check`:
#                                          # missing_frontmatter, unregistered, orphans,
#                                          # open_conflicts, taxonomy, fm_warnings

[verify]
# stamp_docs = false                       # true: refresh last_verified in docs whose checks all pass
# default_timeout = 60                     # seconds per check command

# Named sources share a command template ({arg} is shell-quoted in) and skip probes.
# [verify.sources.db]
# command = "psql \"$DATABASE_URL\" -tA -c {arg}"
# skip_if_unset = ["DATABASE_URL"]         # env missing -> checks SKIP (stay green) until connected

# A check = one fact a doc asserts, verified against its live source.
# kind = "assert": mismatch is DRIFT (fails the run). kind = "track": value legitimately
# moves; compared to a baseline in _index/baselines.json (`librarian verify --update-baselines`).
# [[verify.checks]]
# id      = "orders_has_no_email_column"
# kind    = "assert"
# doc     = "docs/schema.md"               # where the asserted fact lives (DRIFT tells you what to fix)
# source  = "db"
# arg     = "SELECT column_name FROM information_schema.columns WHERE table_name='orders'"
# extract = "column_absent:email"
# expect  = "absent"

[dream]
# The dream cycle (`/librarian-dream`) drafts maintenance proposals — conflict resolutions,
# doc-merge candidates, routing (read_when) fixes + absence-claim audits — propose-only
# on a branch. `librarian status` nudges when the worklist is due.
# nudge_after_days = 14                    # re-nudge on the SAME items after N days (0 = off)
# merge_similarity = 0.6                   # metadata overlap (0-1) to flag a merge candidate

[automation]
# The trust-ladder: which proposal types `librarian apply` may auto-apply. Default for
# EVERY type is "off" (propose-only) — auto-apply is strictly opt-in. Tiers:
#   off    = propose only; a human runs `librarian apply`
#   branch = auto-apply to the dream branch (human reviews + merges)
#   commit = auto-apply AND commit to the dream branch (never main by default)
# Hard caps override this: generative (enrich_create) and irreversible (fix/merge) proposals,
# and archive/merge, can never exceed "branch"; nothing writes to main via tier alone.
# fix = "off"                              # keys: fix ack archive merge set_read_when
# ack = "branch"                           #       resolve_absence enrich_create add_check

[enrich]
# provisional_ttl_days = 30                # a provisional (enriched) doc unreviewed past this
#                                          # many days is flagged in STALENESS.md

[agent]
# claude = true                            # scaffold .claude/ glue on init
# agents_md = true                         # maintain the managed block in AGENTS.md
